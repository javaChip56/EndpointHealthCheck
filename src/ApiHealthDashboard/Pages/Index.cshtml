@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Health Check Dashboard</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item active">Dashboard</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["StatusMessage"] is string statusMessage)
        {
            var statusType = TempData["StatusType"] as string ?? "info";

            <div class="alert alert-@statusType alert-dismissible">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                @statusMessage
            </div>
        }

        <div id="dashboard-live-section"
             data-dashboard-live-section
             data-refresh-url="@Url.Page("/Index", "LiveSection")"
             data-refresh-seconds="@Model.RefreshUiSeconds">
            <partial name="_DashboardLiveSection" model="Model" />
        </div>
    </div>
</section>
