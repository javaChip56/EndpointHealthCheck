@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Health Check Dashboard</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item active">Dashboard</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["StatusMessage"] is string statusMessage)
        {
            var statusType = TempData["StatusType"] as string ?? "info";

            <div class="alert alert-@statusType alert-dismissible">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                @statusMessage
            </div>
        }

        <div class="dashboard-hero card card-outline card-primary">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-lg-8">
                        <span class="hero-kicker">Phase 8 Manual Refresh</span>
                        <h2 class="hero-title">Live endpoint inventory backed by scheduler state</h2>
                        <p class="hero-copy mb-0">
                            The dashboard now reads configured endpoints and current runtime state from the in-memory store.
                            Manual refresh actions reuse the scheduler so they do not interfere with in-progress polling.
                        </p>
                    </div>
                    <div class="col-lg-4">
                        <div class="hero-panel">
                            <div class="hero-stat">
                                <span class="hero-stat-label">Configured endpoints</span>
                                <strong>@Model.Counters.Total</strong>
                            </div>
                            <div class="hero-stat">
                                <span class="hero-stat-label">Scheduler mode</span>
                                <strong>Background loops active</strong>
                            </div>
                            <div class="hero-stat mb-0">
                                <span class="hero-stat-label">Refresh path</span>
                                <strong>Manual + scheduled</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-3 col-6">
                <div class="small-box health-box bg-primary">
                    <div class="inner">
                        <h3>@Model.Counters.Total</h3>
                        <p>Total Endpoints</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-network-wired"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <div class="small-box health-box bg-success">
                    <div class="inner">
                        <h3>@Model.Counters.Healthy</h3>
                        <p>Healthy Endpoints</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-heart"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <div class="small-box health-box bg-warning">
                    <div class="inner">
                        <h3>@Model.Counters.Degraded</h3>
                        <p>Degraded Endpoints</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <div class="small-box health-box bg-danger">
                    <div class="inner">
                        <h3>@(Model.Counters.Unhealthy + Model.Counters.Unknown)</h3>
                        <p>Unhealthy or Unknown</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-radiation"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header border-0">
                        <h3 class="card-title">Monitored Endpoints</h3>
                        <div class="card-tools">
                            <form method="post" asp-page-handler="RefreshAll" class="d-inline">
                                <button type="submit" class="btn btn-tool">
                                    <i class="fas fa-sync-alt mr-1"></i>Refresh All
                                </button>
                            </form>
                        </div>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Status</th>
                                    <th>Last Checked</th>
                                    <th>Last Successful</th>
                                    <th>Duration</th>
                                    <th>Frequency</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Endpoints.Count == 0)
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">No endpoints are configured.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var endpoint in Model.Endpoints)
                                    {
                                        <tr>
                                            <td>
                                                <div class="font-weight-semibold">@endpoint.Name</div>
                                                <small class="text-muted">@endpoint.Id</small>
                                                @if (!endpoint.Enabled)
                                                {
                                                    <div><small class="text-muted">Disabled</small></div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(endpoint.ErrorText))
                                                {
                                                    <div><small class="text-danger">@endpoint.ErrorText</small></div>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge @endpoint.StatusBadgeClass">@endpoint.Status</span>
                                                @if (endpoint.IsPolling)
                                                {
                                                    <div><small class="text-info">Polling now</small></div>
                                                }
                                            </td>
                                            <td>@endpoint.LastCheckedText</td>
                                            <td>@endpoint.LastSuccessfulText</td>
                                            <td>@endpoint.DurationText</td>
                                            <td>@endpoint.FrequencyText</td>
                                            <td class="text-nowrap">
                                                <form method="post" asp-page-handler="RefreshEndpoint" class="d-inline">
                                                    <input type="hidden" name="endpointId" value="@endpoint.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                                        <i class="fas fa-sync-alt"></i>
                                                    </button>
                                                </form>
                                                <a asp-page="/Endpoints/Details" asp-route-id="@endpoint.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card card-outline card-primary">
                    <div class="card-header">
                        <h3 class="card-title">Scheduler Snapshot</h3>
                    </div>
                    <div class="card-body">
                        <div class="progress-group">
                            Healthy
                            <span class="float-right"><b>@Model.Counters.Healthy</b> / @Model.Counters.Total</span>
                            <div class="progress progress-sm">
                                <div class="progress-bar bg-success" style="width: @(Model.Counters.Total == 0 ? 0 : (Model.Counters.Healthy * 100 / Model.Counters.Total))%"></div>
                            </div>
                        </div>
                        <div class="progress-group">
                            Degraded
                            <span class="float-right"><b>@Model.Counters.Degraded</b> / @Model.Counters.Total</span>
                            <div class="progress progress-sm">
                                <div class="progress-bar bg-warning" style="width: @(Model.Counters.Total == 0 ? 0 : (Model.Counters.Degraded * 100 / Model.Counters.Total))%"></div>
                            </div>
                        </div>
                        <div class="progress-group">
                            Unhealthy
                            <span class="float-right"><b>@Model.Counters.Unhealthy</b> / @Model.Counters.Total</span>
                            <div class="progress progress-sm">
                                <div class="progress-bar bg-danger" style="width: @(Model.Counters.Total == 0 ? 0 : (Model.Counters.Unhealthy * 100 / Model.Counters.Total))%"></div>
                            </div>
                        </div>
                        <div class="progress-group">
                            Unknown
                            <span class="float-right"><b>@Model.Counters.Unknown</b> / @Model.Counters.Total</span>
                            <div class="progress progress-sm">
                                <div class="progress-bar bg-secondary" style="width: @(Model.Counters.Total == 0 ? 0 : (Model.Counters.Unknown * 100 / Model.Counters.Total))%"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Current Signals</h3>
                    </div>
                    <div class="card-body p-0">
                        <ul class="todo-list endpoint-notes" data-widget="todo-list">
                            <li>
                                <span class="text">Manual refresh buttons reuse the scheduler interface.</span>
                            </li>
                            <li>
                                <span class="text">Overlap protection keeps one endpoint from being double-polled.</span>
                            </li>
                            <li>
                                <span class="text">Status, duration, and error state come from the runtime store.</span>
                            </li>
                            <li>
                                <span class="text">Details page now reflects real endpoint metadata and current snapshot data.</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
